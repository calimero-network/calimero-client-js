exports[`AbiCodegen should generate types and client from demo ABI: types.ts 1`] = `
"// Generated from ABI schema 0.1.1
// This file contains TypeScript types for the ABI functions

export type GetUserInfoErrorCode = 'USER_NOT_FOUND' | 'INVALID_USER_ID' | 'ACCESS_DENIED';
export type CreateUserErrorCode = 'EMAIL_ALREADY_EXISTS' | 'INVALID_EMAIL' | 'INVALID_AGE';
export type UpdateBalanceErrorCode = 'USER_NOT_FOUND' | 'INSUFFICIENT_FUNDS' | 'INVALID_AMOUNT';
export type GetUserListErrorCode = 'INVALID_LIMIT' | 'INVALID_OFFSET';
export type DeleteUserErrorCode = 'USER_NOT_FOUND' | 'USER_HAS_BALANCE' | 'ACCESS_DENIED';

export type GetUserInfoParams = {
  user_id: number;
  include_private: boolean;
};
export type CreateUserParams = {
  name: string;
  email: string;
  age: number;
  initial_balance: string;
  tags: string[];
  avatar: string | null;
};
export type UpdateBalanceParams = {
  user_id: number;
  amount: string;
  reason: string | null;
};
export type GetUserListParams = {
  limit: number;
  offset: number;
  active_only: boolean;
};
export type DeleteUserParams = {
  user_id: number;
  force: boolean;
};

export type GetUserInfoReturn = {
  name: string;
  email: string;
  age: number;
  balance: string;
  is_active: boolean;
  metadata: string | null;
  tags: string[];
  avatar: string | null;
};
export type CreateUserReturn = {
  user_id: number;
  created_at: number;
};
export type UpdateBalanceReturn = {
  new_balance: string;
  transaction_id: string;
};
export type GetUserListReturn = number[];
export type DeleteUserReturn = void;

export interface CalimeroAbiError {
  code: string;
  data?: unknown;
}
"
`;

